        function changeLanguage(langCode) {
            document.querySelectorAll('.lang-btn').forEach(btn => {
                btn.classList.remove('bg-[#2D4A3E]', 'text-white');
                btn.classList.add('hover:bg-gray-200');
            });
            event.target.classList.add('bg-[#2D4A3E]', 'text-white');
            event.target.classList.remove('hover:bg-gray-200');

            const t = translations[langCode];
            document.getElementById('app-title').innerText = t.appTitle;
            document.getElementById('card-badge').innerText = t.cardBadge;
            document.getElementById('card-back-badge').innerText = t.cardBackBadge;
            document.getElementById('song-title').innerText = t.songTitle;
            document.getElementById('song-artist').innerText = t.songArtist;
            document.getElementById('card-flip-tip').innerText = t.cardFlipTip;
            document.getElementById('scripture-text').innerHTML = t.scripture;
            document.getElementById('scripture-author').innerText = t.scriptureAuthor;
            document.getElementById('btn-donate').innerText = t.btnDonate;
            document.getElementById('ai-title').innerText = t.aiTitle;
            document.getElementById('ai-desc').innerText = t.aiDesc;
            document.getElementById('label-name').innerText = t.labelName;
            document.getElementById('label-mood').innerText = t.labelMood;
            document.getElementById('btn-oracle').innerText = t.btnOracle;
            document.getElementById('modal-donate-title').innerText = t.modalDonateTitle;
            document.getElementById('modal-donate-desc').innerText = t.modalDonateDesc;
            document.getElementById('modal-donate-memo').innerText = t.modalDonateMemo;
            document.getElementById('modal-donate-quote').innerText = t.modalDonateQuote;
        }

        window.addEventListener('DOMContentLoaded', () => {
            const systemLang = (navigator.language || navigator.userLanguage).toLowerCase();
            let matched = 'vi';
            if (systemLang.startsWith('en')) matched = 'en';
            else if (systemLang.startsWith('ko')) matched = 'ko';
            else if (systemLang.startsWith('ja')) matched = 'ja';
            else if (systemLang.startsWith('zh')) matched = 'zh';
            else if (systemLang.startsWith('fr')) matched = 'fr';
            else if (systemLang.startsWith('ru')) matched = 'ru';
            
            const buttons = document.querySelectorAll('.lang-btn');
            buttons.forEach(btn => {
                if (btn.innerText.toLowerCase() === (matched === 'vi' ? 'vn' : matched)) {
                    btn.click();
                }
            });
        });

        function flipCard() {
            if (event.target.closest('#play-btn') || event.target.closest('#progress') || event.target.closest('#mute-btn')) return;
            card3D.classList.toggle('flipped');
        }

        function togglePlay() {
            if (audio.paused) {
                audio.play().catch(err => {
                    console.log("Cần chạm màn hình trước khi phát.");
                });
                playIcon.classList.replace('fa-play', 'fa-pause');
            } else {
                audio.pause();
                playIcon.classList.replace('fa-pause', 'fa-play');
            }
        }

        function rewindAudio() {
            audio.currentTime = 0;
        }

        function toggleMute() {
            audio.muted = !audio.muted;
            if (audio.muted) {
                muteBtn.innerHTML = '<i class="fas fa-volume-mute text-red-500"></i>';
            } else {
                muteBtn.innerHTML = '<i class="fas fa-volume-up"></i>';
            }
        }

        audio.ontimeupdate = () => {
            const percent = (audio.currentTime / audio.duration) * 100;
            progress.value = percent || 0;
            
            let curMins = Math.floor(audio.currentTime / 60);
            let curSecs = Math.floor(audio.currentTime % 60);
            document.getElementById('current-time').innerText = curMins + ":" + (curSecs < 10 ? '0'+curSecs : curSecs);
            
            if(audio.duration) {
                let durMins = Math.floor(audio.duration / 60);
                let durSecs = Math.floor(audio.duration % 60);
                document.getElementById('duration').innerText = durMins + ":" + (durSecs < 10 ? '0'+durSecs : durSecs);
            }
        };

        progress.oninput = () => {
            const time = (progress.value / 100) * audio.duration;
            audio.currentTime = time;
        };

        async function getZenAdvice() {
            const name = document.getElementById('ai-user-name').value || "Nhà thám hiểm";
            const mood = document.getElementById('ai-user-mood').value;
            const btn = document.getElementById('btn-oracle');
            const resBox = document.getElementById('ai-response-box');
            const resText = document.getElementById('ai-response-text');

            btn.innerText = "Sư phụ đang nghe con nói...";
            btn.disabled = true;

            const systemPrompt = "Bạn là Sư phụ Chánh Niệm AI Trí Tuệ tại Đà Lạt. Hãy viết 1 câu khuyên giải chánh niệm cực ngắn, ấm áp, xoa dịu lòng người bằng đúng ngôn ngữ của người hỏi.";
            const userQuery = `Hãy viết một câu lời chúc/khuyên giải chánh niệm cho con tên là ${name}, hiện con đang có tâm trạng rất ${mood}. Hãy gọi tên con thật trìu mến.`;
            const apiKey = ""; 
            const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-3-flash-preview:generateContent?key=${apiKey}`;

            const payload = {
                contents: [{ parts: [{ text: userQuery }] }],
                systemInstruction: {
                    parts: [{ text: systemPrompt }]
                }
            };

            try {
                const response = await fetch(apiUrl, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const result = await response.json();
                const advice = result.candidates?.[0]?.content?.parts?.[0]?.text || "Hãy hít thở sâu, mọi bão giông rồi sẽ qua.";
                resText.innerText = advice;
                resBox.classList.remove('hidden');
            } catch (error) {
                resText.innerText = `Chào ${name}, hãy hít thật sâu, thở thật nhẹ. Bình an luôn ở bên con ngay lúc này.`;
                resBox.classList.remove('hidden');
            } finally {
                btn.innerText = "Nghe sư phụ chỉ dạy";
                btn.disabled = false;
            }
        }

        function showContributionBox() { document.getElementById('contribution-modal').classList.remove('hidden'); }
        function closeContributionBox() { document.getElementById('contribution-modal').classList.add('hidden'); }
        function showDeployGuide() { document.getElementById('deploy-modal').classList.remove('hidden'); }
        function closeDeployGuide() { document.getElementById('deploy-modal').classList.add('hidden'); }

        function createPetals() {
            const container = document.getElementById('petal-container');
            for (let i = 0; i < 12; i++) {
                const petal = document.createElement('div');
                petal.className = 'lotus-petal';
                petal.style.left = `${Math.random() * 100}vw`;
                petal.style.animationDuration = `${Math.random() * 8 + 10}s`;
                petal.style.animationDelay = `${Math.random() * 5}s`;
                petal.style.width = `${Math.random() * 15 + 15}px`;
                petal.style.height = petal.style.width;
                petal.innerHTML = `<img src="https://api.iconify.design/noto:lotus.svg" class="w-full h-full opacity-40">`;
                container.appendChild(petal);
            }
        }
        window.addEventListener('load', createPetals);
    </script>
